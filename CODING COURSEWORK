class StocksPage:
    def __init__(self, window):
        self.window = window
        self.current_price = 0 # store price for trade
        self.current_ticker = "" # store ticker for trade

        tk.Label(window, text = "STOCK SEARCH", font = ("Abadi", 28, "bold"), fg = "white", bg = "black").pack(pady = 10)
        self.search_entry = tk.Entry(window, font = ("Abadi", 16)) # user input box
        self.search_entry.pack(pady = 5)
        tk.Button(window, text = "Search", font = ("Abadi", 14), command = self.search_stock).pack(pady = 5)

        self.qty_frame = tk.Frame(window, bg = "black") # container for quantity
        self.qty_frame.pack(pady = 5)
        tk.Label(self.qty_frame, text = "Quantity:", font = ("Abadi", 12), fg = "white", bg = "black").pack(side="left")
        self.qty_entry = tk.Entry(self.qty_frame, font = ("Abadi", 12), width = 5)
        self.qty_entry.insert(0, "1") # default quantity
        self.qty_entry.pack(side="left", padx = 5)

        self.trade_frame = tk.Frame(window, bg = "black") # container for buttons
        self.trade_frame.pack(pady = 10)

        self.buy_btn = tk.Button(self.trade_frame, text = "BUY", bg = "green", fg = "white", font = ("Abadi", 12, "bold"), command = self.buy_stock, state = "disabled")
        self.buy_btn.pack(side = "left", padx = 10) # buy button

        self.sell_btn = tk.Button(self.trade_frame, text = "SELL", bg = "red", fg = "white", font = ("Abadi", 12, "bold"), command = self.sell_stock, state = "disabled")
        self.sell_btn.pack(side = "left", padx = 10) # sell button

        self.graph_frame = tk.Frame(window, bg = "black") # frame for graph
        self.graph_frame.pack(fill = "both", expand = True)

    def get_quantity_value(self):
        try:
            quantity = int(self.qty_entry.get()) # point to quantity input
            if quantity <= 0: return 0
            return quantity
        except ValueError:
            return 0 

    def search_stock(self):
        ticker_symbol = self.search_entry.get().upper().strip() # get ticker text
        if not ticker_symbol: return
        try:
            end_date = datetime.today()
            start_date = end_date - timedelta(days=30) 
            aggregates = list(client.get_aggs(ticker_symbol, 1, "day", start_date.strftime("%Y-%m-%d"), end_date.strftime("%Y-%m-%d")))
            
            if len(aggregates) == 0:
                messagebox.showerror("Error", "Stock ticker not found.")
                return

            self.current_price = aggregates[-1].close # save price
            self.current_ticker = ticker_symbol # save ticker
            self.buy_btn.config(state = "normal") # enable buy
            self.sell_btn.config(state = "normal") # enable sell

            dates = [datetime.fromtimestamp(agg.timestamp / 1000) for agg in aggregates]
            prices = [agg.close for agg in aggregates] 
            self.plot_graph(ticker_symbol, dates, prices) # call plot method
        except Exception:
            messagebox.showerror("Error", "API issue or invalid ticker.")

    def buy_stock(self):
        quantity_to_buy = self.get_quantity_value()
        if quantity_to_buy == 0:
            messagebox.showwarning("Warning", "Enter a valid quantity!")
            return
            
        total_cost = self.current_price * quantity_to_buy # calculate total cost
        if sim_data.balance >= total_cost:
            sim_data.balance -= total_cost # subtract money
            sim_data.history.append(f"Bought {quantity_to_buy} {self.current_ticker} @ ${self.current_price:.2f}") # log trade
            sim_data.portfolio[self.current_ticker] = sim_data.portfolio.get(self.current_ticker, 0) + quantity_to_buy # update shares
            messagebox.showinfo("Success", f"Purchased {quantity_to_buy} shares of {self.current_ticker}")
        else:
            messagebox.showwarning("Failed", "Insufficient funds!") 

    def sell_stock(self):
        quantity_to_sell = self.get_quantity_value()
        shares_owned = sim_data.portfolio.get(self.current_ticker, 0)
        
        if quantity_to_sell == 0:
            messagebox.showwarning("Warning", "Enter a valid quantity!")
            return

        if shares_owned >= quantity_to_sell:
            sim_data.balance += (self.current_price * quantity_to_sell) # add sale money
            sim_data.history.append(f"Sold {quantity_to_sell} {self.current_ticker} @ ${self.current_price:.2f}") # log trade
            sim_data.portfolio[self.current_ticker] -= quantity_to_sell # subtract shares
            messagebox.showinfo("Success", f"Sold {quantity_to_sell} shares of {self.current_ticker}")
        else:
            messagebox.showwarning("Failed", f"You only own {shares_owned} shares!") 

    def plot_graph(self, ticker, dates, prices):
        for widget in self.graph_frame.winfo_children():
            widget.destroy() # clear old graph
        fig, ax = plt.subplots(figsize = (8, 4), facecolor = "black") # create black plot
        ax.plot(dates, prices, color="#00ff00") # plot line in green
        ax.set_title(f"{ticker} Price: ${self.current_price:.2f}", color = "white") # set title
        ax.tick_params(colors = "white") # set axis to white
        canvas = FigureCanvasTkAgg(fig, master = self.graph_frame) # show in tkinter
        canvas.draw()
        canvas.get_tk_widget().pack(fill = "both", expand = True)

class NextButton:
    def __init__(self, next_button):
        self.button = tk.Button(next_button, text = "Next", font = ("Abadi", 20), command = self.open_new_page)
        self.button.pack(pady = 20) # display button

    def open_new_page(self):
        new_window = tk.Toplevel() # open new window
        new_window.title("Stock Market Simulator")
        screen_width = new_window.winfo_screenwidth()
        screen_height = new_window.winfo_screenheight()
        new_window.geometry(f"{screen_width}x{screen_height}+0+0") # fullscreen
        new_window.configure(bg = "black")
        nav_frame = tk.Frame(new_window, bg = "grey") # top nav bar
        nav_frame.pack(side = "top", fill = "x")
        
        home_frame = tk.Frame(new_window, bg = "black") # home page container
        stocks_frame = tk.Frame(new_window, bg = "black") # stocks page container
        home_frame.pack(fill = "both", expand = True) # show home first

        def refresh_home_data():
            for widget in home_frame.winfo_children(): widget.destroy() # clear home
            Portfolio(home_frame) # reload portfolio
            AccountBalance(home_frame) # reload balance
            RecentTransactions(home_frame) # reload history
            TipsBox(home_frame) # reload tips

        def show_home_screen():
            plt.close('all') # save memory
            stocks_frame.pack_forget() # hide stocks
            refresh_home_data() # update data
            home_frame.pack(fill = "both", expand = True) # show home

        def show_stocks_screen():
            plt.close('all') # save memory
            home_frame.pack_forget() # hide home
            stocks_frame.pack(fill = "both", expand = True) # show stocks

        refresh_home_data() # initial load
        StocksPage(stocks_frame) # initial load

        tk.Button(nav_frame, text="HOME PAGE", font=("Abadi", 14), command=show_home_screen).pack(side="left", padx=10, pady=10)
        tk.Button(nav_frame, text="STOCKS PAGE", font=("Abadi", 14), command=show_stocks_screen).pack(side="left", padx=10, pady=10)

