class Portfolio:
    def __init__(self, window):
        self.window = window
        self.portfolio_frame = tk.Frame(
            window,
            bg = "#1a1a1a", # dark grey background
            borderwidth = 2,
            relief = "sunken"
        )
        self.portfolio_frame.pack(side = "left", fill = "both", expand = True, padx = 20, pady = 60) # position on left
        
        self.header = tk.Label(
            self.portfolio_frame,
            text = "PORTFOLIO BREAKDOWN",
            font = ("Abadi", 24, "bold"), # font style/size
            bg = "#1a1a1a", # set background colour
            fg = "white" # set text colour
        )
        self.header.pack(pady = 10)
        self.create_chart() # start chart generation

    def create_chart(self):
        # Using clear variables instead of k and v
        if not sim_data.portfolio or all(count == 0 for count in sim_data.portfolio.values()):
            labels = ["Cash"] # show cash only if empty
            sizes = [100]
        else:
            # Descriptive names for keys and values
            labels = ["Cash"] + [ticker for ticker, count in sim_data.portfolio.items() if count > 0] 
            sizes = [sim_data.balance] + [count * 100 for ticker, count in sim_data.portfolio.items() if count > 0]

        colors = ["#4CAF50", "#2196F3", "#9C27B0", "#FF9800", "#E91E63"]
        fig, ax = plt.subplots(figsize = (5, 5), facecolor = "#1a1a1a") # create plot area
        ax.pie(sizes, labels = labels, colors = colors, autopct = "%1.1f%%", startangle = 140, textprops = {"color": "w"})
        ax.axis("equal") # keep chart circular
        self.canvas = FigureCanvasTkAgg(fig, master = self.portfolio_frame) # place chart in frame
        self.canvas.draw()
        self.canvas.get_tk_widget().pack(fill = "both", expand = True, padx = 10, pady = 10)

